{%- comment -%}
  Forefront Chatbot — App Embed Block
  This block loads the Forefront chatbot widget on every page of the store.
  Store owners can configure settings from the Shopify theme editor.
{%- endcomment -%}

<div
  id="forefront-widget-root"
  data-chatbot-id="{{ block.settings.chatbot_id }}"
  data-position="{{ block.settings.position }}"
  data-primary-color="{{ block.settings.primary_color }}"
  data-welcome-message="{{ block.settings.welcome_message }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  style="display:none;"
></div>

{{ 'widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:widget_embed.name",
  "target": "body",
  "javascript": "widget.js",
  "stylesheet": "widget.css",
  "settings": [
    {
      "type": "text",
      "id": "chatbot_id",
      "label": "t:widget_embed.settings.chatbot_id.label",
      "info": "t:widget_embed.settings.chatbot_id.info"
    },
    {
      "type": "text",
      "id": "backend_url",
      "label": "t:widget_embed.settings.backend_url.label",
      "default": "https://your-backend.com",
      "info": "t:widget_embed.settings.backend_url.info"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "t:widget_embed.settings.primary_color.label",
      "default": "#4F46E5"
    },
    {
      "type": "select",
      "id": "position",
      "label": "t:widget_embed.settings.position.label",
      "options": [
        { "value": "bottom-right", "label": "t:widget_embed.settings.position.bottom_right" },
        { "value": "bottom-left", "label": "t:widget_embed.settings.position.bottom_left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "text",
      "id": "welcome_message",
      "label": "t:widget_embed.settings.welcome_message.label",
      "default": "Hi! How can we help you today?"
    }
  ]
}
{% endschema %}
